# Salin file ini menjadi .env dan isi dengan nilai asli kamu
# JANGAN commit file .env ke repository!

# Supabase — https://supabase.com → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google Gemini AI — https://aistudio.google.com → Get API Key
GEMINI_API_KEY=your_gemini_api_key_here

# ExchangeRate API — https://exchangerate-api.com → free plan
EXCHANGERATE_API_KEY=your_exchangerate_api_key_here
